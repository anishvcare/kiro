# ============================================================================
# Production .env template for the Laravel API
# Deploy target: https://api.matri.nokkoo.in  (cPanel, PHP 8.2, MariaDB 10.6)
#
# HOW TO USE:
#   1. On the server, copy this to `.env`  ->  cp .env.production.example .env
#   2. Fill in the values marked CHANGE_ME (especially DB + Google secret).
#   3. Run:  php artisan key:generate
#   NEVER commit the real .env or share these secrets.
# ============================================================================

APP_NAME="Nokkoo Matri"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.matri.nokkoo.in

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logging — keep error-level only in production
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ── Database (cPanel MySQL/MariaDB) ─────────────────────────────────────────
# Create the DB + user in cPanel > MySQL Databases. cPanel prefixes names with
# your account, e.g. uddjzwrz_matri and uddjzwrz_matriuser.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=CHANGE_ME_db_name
DB_USERNAME=CHANGE_ME_db_user
DB_PASSWORD=CHANGE_ME_db_password

# ── Sessions / cache / queue ────────────────────────────────────────────────
# Auth is Bearer-token (Sanctum), so sessions are not used for the SPA, but
# Laravel still needs a driver. `database` works (tables are created by migrate)
# or use `file` to avoid extra tables.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── CORS / frontend origin ──────────────────────────────────────────────────
# Must match the SPA origin exactly (no trailing slash). Read by config/cors.php.
FRONTEND_URL=https://matri.nokkoo.in

# ── Google OAuth (Socialite) ────────────────────────────────────────────────
# Required for "Login with Google". Get these from Google Cloud Console >
# APIs & Services > Credentials (the same OAuth client used by the frontend).
GOOGLE_CLIENT_ID=1021276313913-eq8rpnjpoip4rmmmnsbupmoql0dmhdnk.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME_google_client_secret
GOOGLE_REDIRECT_URI=https://api.matri.nokkoo.in/api/auth/google/callback

# ── Mail (optional; defaults to log) ────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@matri.nokkoo.in"
MAIL_FROM_NAME="${APP_NAME}"

# ── Redis (not required; left for completeness) ─────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

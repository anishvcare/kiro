APP_NAME="FMGE Daily Trainer"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.fmgetrainer.com

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=fmge_trainer
DB_USERNAME=fmge_user
DB_PASSWORD=your_secure_password

# Redis Cache
CACHE_STORE=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Queue
QUEUE_CONNECTION=redis

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@fmgetrainer.com
MAIL_FROM_NAME="FMGE Trainer"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3000,fmgetrainer.com,www.fmgetrainer.com

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://fmgetrainer.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase
FIREBASE_CREDENTIALS=storage/firebase-credentials.json
FIREBASE_DATABASE_URL=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Cloudflare R2 Storage
FILESYSTEM_DISK=r2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=fmge-trainer
R2_URL=https://storage.fmgetrainer.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

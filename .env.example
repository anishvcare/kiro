# Server Configuration
NODE_ENV=development
PORT=8080

# Database Configuration
DB_HOST=localshop-mysql.mysql.database.azure.com
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=local_shopping_platform
DB_NAME_TEST=local_shopping_platform_test
DB_LOGGING=false
DB_SSL=true

# Azure Configuration
WEBSITE_NODE_DEFAULT_VERSION=~22

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Email (SMTP)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@localshop.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Socket.IO
SOCKET_CORS_ORIGIN=http://localhost:5173


# ============================================
# Firebase (backend) - required for customer PHONE OTP login
# Paste the FULL service-account JSON as a single-line string.
# Get it from: Firebase Console > Project Settings > Service accounts >
# "Generate new private key". This same var is also used for FCM push.
# ============================================
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}


# ============================================
# WhatsApp OTP login (customer authentication)
# Default provider is Meta's WhatsApp Cloud API. Create a Meta app + WhatsApp
# Business Account, add a phone number, and get an approved "Authentication"
# category message template that contains the code in the body and a one-tap
# "Copy code" URL button.
# ============================================
WHATSAPP_PROVIDER=meta
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_OTP_TEMPLATE=otp_verification
WHATSAPP_OTP_TEMPLATE_LANG=en
WHATSAPP_API_VERSION=v21.0

# OTP behaviour (optional overrides)
OTP_TTL_MS=300000
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_MS=30000
# Set to "true" only in local/dev to return the OTP in the API response for testing.
OTP_DEBUG=false

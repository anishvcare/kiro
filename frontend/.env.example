# Frontend build-time environment variables (Vite).
# Copy to .env (or set in your hosting build settings) and fill in real values.

# Base URL of the backend API
VITE_API_URL=/api

# ============================================
# Firebase Web config - required for customer PHONE OTP (SMS) login.
# Get these from: Firebase Console > Project Settings > General >
# "Your apps" > Web app > SDK setup and configuration > Config.
# Also enable Authentication > Sign-in method > Phone in the Firebase Console,
# and add your production domain under Authentication > Settings > Authorized domains.
# ============================================
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
